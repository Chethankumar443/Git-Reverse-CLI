{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd landing && npm install",
  "buildCommand": "cd landing && npm run build",
  "outputDirectory": "landing/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|png|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
