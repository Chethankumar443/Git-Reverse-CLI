{
  "name": "git-reverse-cli",
  "version": "1.1.0",
  "description": "Reverse-engineer any GitHub repository into a structured recreation prompt using LLMs",
  "keywords": [
    "github",
    "reverse-engineer",
    "llm",
    "cli",
    "openrouter",
    "prompt-engineering"
  ],
  "author": "git-reverse contributors",
  "license": "MIT",
  "type": "module",
  "bin": {
    "git-reverse": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "tsup",
    "start": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build && npm run typecheck",
    "astro:dev": "astro dev",
    "astro:build": "astro build",
    "astro:preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/react": "^3.0.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^21.0.2",
    "astro": "^4.0.0",
    "axios": "^1.7.9",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "clipboardy": "^5.3.1",
    "conf": "^13.0.1",
    "fast-glob": "^3.3.3",
    "figures": "^6.1.0",
    "gpt-tokenizer": "^3.4.0",
    "ignore": "^7.0.5",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^0.257.0",
    "marked": "^14.1.4",
    "marked-terminal": "^7.3.0",
    "meow": "^14.1.0",
    "motion": "^10.16.2",
    "nanoid": "^5.0.9",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "terminal-link": "^3.0.0",
    "update-notifier": "^7.3.1",
    "vaul": "^0.9.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
