{
  "name": "git-reverse-cli",
  "version": "1.2.0",
  "description": "Reverse-engineer any GitHub repository into a structured recreation prompt using LLMs",
  "keywords": [
    "github",
    "reverse-engineer",
    "llm",
    "cli",
    "openrouter",
    "prompt-engineering"
  ],
  "author": "git-reverse contributors",
  "license": "MIT",
  "type": "module",
  "bin": {
    "git-reverse": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "homepage": "https://github.com/chethankumar/git-reverse",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chethankumar/git-reverse.git"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build:landing": "esbuild src/landing-react/index.tsx --bundle --outfile=landing/aurora-bg.bundle.js --minify",
    "build": "npm run build:landing && tsup && node scripts/build-web.js",
    "start": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@napi-rs/keyring": "^1.3.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^21.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "astro": "^6.4.8",
    "axios": "^1.7.9",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "clipboardy": "^5.3.1",
    "conf": "^13.0.1",
    "esbuild": "^0.28.1",
    "fast-glob": "^3.3.3",
    "figures": "^6.1.0",
    "framer-motion": "^12.40.0",
    "gpt-tokenizer": "^3.4.0",
    "ignore": "^7.0.5",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.257.0",
    "marked": "^14.1.4",
    "marked-terminal": "^7.3.0",
    "meow": "^14.1.0",
    "motion": "^10.16.2",
    "nanoid": "^5.0.9",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "terminal-link": "^3.0.0",
    "three": "^0.184.0",
    "update-notifier": "^7.3.1",
    "vaul": "^0.9.0",
    "vite": "^8.0.16",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/keytar": "^4.4.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/chethankumar/git-reverse/issues"
  }
}
